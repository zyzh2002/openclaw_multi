# OpenClaw 镜像版本
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# 沙箱模式（1=启用，0=禁用）
OPENCLAW_SANDBOX=1

# 各实例 Gateway Token（可留空使用默认值）
# 注意：Web 面板使用 auth:{} 无认证，Token 仅供内部绑定安全
OPENCLAW_GATEWAY_TOKEN_1=
OPENCLAW_GATEWAY_TOKEN_2=
OPENCLAW_GATEWAY_TOKEN_3=
OPENCLAW_GATEWAY_TOKEN_4=

# 宿主机代理（统一，无密码），留空则不启用
# 容器通过 host.docker.internal 访问宿主机
# Windows/macOS 示例: http://host.docker.internal:7890
# Linux 示例: http://host.docker.internal:7890（代理需监听 0.0.0.0）
HTTP_PROXY_URL=
HTTPS_PROXY_URL=

# SOCKS5 代理示例: socks5://host.docker.internal:1080
ALL_PROXY_URL=
